{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server.js"
        },
        {
            "src": "/(.*\\.(css|js|html|png|ico|svg|woff|woff2|ttf))",
            "dest": "public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "public/index.html"
        }
    ]
}